# Upstream API key (OpenAI / Azure OpenAI / vLLM / Ollama / AI Gateway).
# Sensitive — register separately for Production/Staging via your container
# orchestrator's secret store (Docker `--env-file`, k8s Secret, etc.).
AI_RELAY_API_KEY=

# Upstream base URL. Optional. Default: SDK built-in (https://api.openai.com/v1).
# Set to point at Azure OpenAI, a self-hosted vLLM/Ollama gateway, or a local mock.
AI_RELAY_BASE_URL=

# Bearer token sent by the MCP host. Sensitive — generate as 32+ random bytes.
AI_RELAY_AUTH_TOKEN=

# Upstream model id forwarded on every tools/call. Required — the caller-facing
# tool input does not accept `model`; the server is the single source of truth.
AI_RELAY_MODEL=

# Sampling temperature (0..2). Optional. Forwarded on every upstream call.
AI_RELAY_TEMPERATURE=

# Positive integer. Forwarded as `max_tokens` on every upstream call. No
# server-side clamp is applied — set conservatively to control cost.
AI_RELAY_MAX_TOKENS=

# Nucleus sampling cutoff (0..1). Optional. Forwarded on every upstream call.
AI_RELAY_TOP_P=

# Stop sequence(s). Single value or comma-separated list (e.g. `END` or `END,STOP`).
AI_RELAY_STOP=

# Integer milliseconds for upstream request timeout. Default: 60000
AI_RELAY_REQUEST_TIMEOUT_MS=

# HTTP listen port for the Hono app server. Default: 8787
AI_RELAY_PORT=

# --- Script-only (not consumed by the server) ---

# Default tool name used by `pnpm inspect` for tools/call. Default: chat-completions.
# Override with `--tool=...` per-call.
MCP_TOOL=

# Default user message used by `pnpm inspect` for tools/call. Default: ping.
# Override with `--message=...` per-call.
MCP_MESSAGE=

# Default MCP endpoint URL used by `pnpm inspect` and `pnpm verify`.
# Default: http://localhost:8787/api/mcp. Override with `--url=...`.
MCP_URL=

# (Removed in 0.10.0: MCP_MODEL, VERIFY_MODEL — the caller-facing MCP tool input
# no longer accepts `model`; configure AI_RELAY_MODEL on the server instead.)
