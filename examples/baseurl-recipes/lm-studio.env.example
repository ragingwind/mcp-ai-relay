# LM Studio (local) — OpenAI-compatible Chat Completions
# Docs: https://lmstudio.ai/docs/local-server
# status: untested — community contributions welcome
# (Open a PR with MCP Inspector evidence to mark this verified)

# LM Studio ignores the API key — any non-empty value works
AI_RELAY_API_KEY=lm-studio
AI_RELAY_BASE_URL=http://localhost:1234/v1
AI_RELAY_MODEL=local-model

# Optional sampling overrides
# AI_RELAY_TEMPERATURE=0.7
# AI_RELAY_MAX_TOKENS=4096
# AI_RELAY_TOP_P=1.0
