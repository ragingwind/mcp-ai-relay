# Ollama (local) — OpenAI-compatible Chat Completions
# Docs: https://github.com/ollama/ollama/blob/main/docs/openai.md
# status: untested — community contributions welcome
# (Open a PR with MCP Inspector evidence to mark this verified)

# Ollama ignores the API key — any non-empty value works
AI_RELAY_API_KEY=ollama
AI_RELAY_BASE_URL=http://localhost:11434/v1
AI_RELAY_MODEL=llama3.2

# Optional sampling overrides
# AI_RELAY_TEMPERATURE=0.7
# AI_RELAY_MAX_TOKENS=4096
# AI_RELAY_TOP_P=1.0
