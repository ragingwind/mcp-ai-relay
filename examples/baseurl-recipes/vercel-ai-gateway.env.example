# Vercel AI Gateway — OpenAI-compatible multi-provider proxy
# Docs: https://vercel.com/docs/ai-gateway
# status: untested — community contributions welcome
# (Open a PR with MCP Inspector evidence to mark this verified)

AI_RELAY_API_KEY=vck_...
AI_RELAY_BASE_URL=https://gateway.ai.vercel.app/v1
AI_RELAY_MODEL=openai:gpt-4o

# Optional sampling overrides
# AI_RELAY_TEMPERATURE=0.7
# AI_RELAY_MAX_TOKENS=4096
# AI_RELAY_TOP_P=1.0
