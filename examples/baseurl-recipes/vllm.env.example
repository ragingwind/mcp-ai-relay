# vLLM (self-hosted) — OpenAI-compatible Chat Completions
# Docs: https://docs.vllm.ai/en/latest/serving/openai_compatible_server.html
# status: untested — community contributions welcome
# (Open a PR with MCP Inspector evidence to mark this verified)

# vLLM default for keyless setups — change if your server requires auth
AI_RELAY_API_KEY=EMPTY
AI_RELAY_BASE_URL=http://localhost:8000/v1
AI_RELAY_MODEL=meta-llama/Llama-3-8B-Instruct

# Optional sampling overrides
# AI_RELAY_TEMPERATURE=0.7
# AI_RELAY_MAX_TOKENS=4096
# AI_RELAY_TOP_P=1.0
