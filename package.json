{
  "name": "mcp-ai-relay",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Jimmy Moon <ragingwind@gmail.com>",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "scripts": {
    "dev": "node scripts/check-dev-env.mjs && pnpm -r --filter ai-relay build && pnpm -F app dev",
    "build": "pnpm -r build",
    "build:sdk": "pnpm --filter ai-relay build",
    "start": "pnpm -F app start",
    "typecheck": "pnpm --filter ai-relay build && tsc --noEmit && pnpm --filter ai-relay exec tsc --noEmit && pnpm -F app exec tsc --noEmit",
    "lint": "biome check .",
    "test": "pnpm --filter ai-relay build && vitest run --passWithNoTests",
    "test:unit": "pnpm --filter ai-relay test",
    "test:integration": "pnpm --filter ai-relay build && vitest run --project integration --passWithNoTests",
    "verify": "node scripts/verify.mjs",
    "inspect": "node scripts/mcp-inspect.mjs"
  },
  "dependencies": {
    "ai-relay": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "msw": "^2.14.3",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "next": "npm:empty-npm-package@1.0.0",
      "react": "npm:empty-npm-package@1.0.0",
      "react-dom": "npm:empty-npm-package@1.0.0",
      "@modelcontextprotocol/sdk": "1.26.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "*",
        "react-dom": "*"
      }
    }
  }
}
