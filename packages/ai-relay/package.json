{
  "name": "ai-relay",
  "version": "0.3.1",
  "description": "Provider-agnostic MCP relay SDK — embed Chat Completions and (future) Anthropic Messages, Gemini, and unified-gateway tools in any MCP server.",
  "license": "MIT",
  "author": "Jimmy Moon <ragingwind@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "import": "./dist/openai/index.js"
    },
    "./env": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    }
  },
  "bin": {
    "ai-relay": "./dist/bin/cli.js",
    "ai-relay-mcp": "./dist/bin/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('node:fs');fs.chmodSync('dist/bin/cli.js',0o755);fs.chmodSync('dist/bin/mcp.js',0o755);\"",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run --passWithNoTests",
    "test:bin": "vitest run tests/integration/bin-tarball.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.26",
    "openai": "^6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
